# ─── Identidade ───
AGENT_NAME=LidIA
ENV=production
DEBUG=false

# ─── OpenAI ───
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.5
OPENAI_MAX_TOKENS=2000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── uazapi v2 ───
UAZ_BASE_URL=https://benitechlab.uazapi.com
UAZ_TOKEN=<instance_token>
UAZ_WEBHOOK_SECRET=

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://lidia:lidia_secret@db:5432/lidia
REDIS_URL=redis://redis:6379/0
REDIS_BUFFER_SECONDS=10

# ─── Conversa ───
HISTORY_LIMIT=40
RAG_ENABLED=true
RAG_TOP_K=7

# ─── Google Drive / Sheets ───
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google-sa.json
DRIVE_FOLDER_DOCUMENTS=<folder_id>
DRIVE_FOLDER_MEDIA=<folder_id>
SHEETS_EVENTOS_ID=<sheet_id>
SHEETS_INFORMACOES_ID=<sheet_id>
SHEETS_PLANO_LEITURA_ID=<sheet_id>
SHEETS_LOG_NOTIFICACOES_ID=<sheet_id>
SHEETS_LOG_ORACAO_ID=<sheet_id>

# ─── Gmail (notificações) ───
GMAIL_FROM=lidia@paes.org.br
GMAIL_SERVICE_ACCOUNT_JSON=/app/secrets/gmail-sa.json

# ─── Admin (prefixos TreinoIA12, etc.) ───
ADMIN_PHONES=5581999999999,5581888888888

# ─── Handoff ───
HANDOFF_PAUSE_MINUTES=30
HANDOFF_KEYWORD_OFF=Roberta aqui!
HANDOFF_KEYWORD_ON=té mais!

# ─── Workers ───
TRAINING_SCHEDULE_CRON=0 3 * * *
SHEETS_SYNC_INTERVAL_MINUTES=15

# ─── Misc ───
DRY_RUN=false
LOG_LEVEL=INFO
